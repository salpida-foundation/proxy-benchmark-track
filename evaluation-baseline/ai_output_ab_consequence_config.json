{
  "evaluator_name": "AI Output A/B consequence evaluator",
  "evaluator_version": "v0.1",
  "track": "SICS Human-State Proxy Benchmark Track",
  "repository_surface": "public-helper",
  "mode": "synthetic-only",
  "input_file": "evaluation-baseline/synthetic_ab_inputs/synthetic_ai_output_ab_001.json",
  "output_report_file": "evaluation-baseline/demo_output/ai_output_ab_demo_report_001.json",
  "required_boundary_flags": {
    "synthetic_only": true,
    "real_participant_data": false,
    "raw_human_data_included": false,
    "real_conversation_included": false,
    "real_phone_recording_included": false,
    "real_call_transcript_included": false,
    "real_session_log_included": false,
    "clinical_data_included": false,
    "diagnostic_data_included": false,
    "therapeutic_data_included": false,
    "counseling_data_included": false,
    "surveillance_data_included": false,
    "sal_meter_raw_input_included": false,
    "cais_trace_data_included": false,
    "production_intervention_log_included": false
  },
  "scoring_rule": {
    "type": "synthetic_helper_placeholder",
    "formula": "score = (-1 * overload_delta) + recovery_delta + relational_stability_delta",
    "weights": {
      "overload_delta": -1.0,
      "recovery_delta": 1.0,
      "relational_stability_delta": 1.0
    },
    "higher_score_is_better": true,
    "tie_breakers": [
      "lower_overload_delta",
      "higher_recovery_delta",
      "higher_relational_stability_delta",
      "termination_gate_pass"
    ],
    "not_validation": true,
    "not_clinical_metric": true,
    "not_diagnostic_metric": true,
    "not_therapeutic_metric": true,
    "not_counseling_metric": true,
    "not_mediation_effectiveness_validation": true,
    "not_benchmark_validation": true,
    "not_scientific_truth_validation": true
  },
  "termination_gate_rule": {
    "type": "synthetic_helper_placeholder",
    "preferred_status": "pass",
    "hold_status": "hold",
    "fail_status": "fail",
    "not_real_world_accuracy_validation": true
  },
  "comparison_fields": [
    "output_condition_id",
    "output_summary",
    "overload_delta",
    "recovery_delta",
    "relational_stability_delta",
    "termination_gate_status"
  ],
  "report_fields": [
    "comparison_id",
    "synthetic_only",
    "condition_a_id",
    "condition_b_id",
    "overload_delta_a",
    "overload_delta_b",
    "recovery_delta_a",
    "recovery_delta_b",
    "relational_stability_delta_a",
    "relational_stability_delta_b",
    "termination_gate_status_a",
    "termination_gate_status_b",
    "synthetic_score_a",
    "synthetic_score_b",
    "preferred_synthetic_condition",
    "preference_reason",
    "data_quality_flag",
    "boundary_statement"
  ],
  "prohibited_input_fields": [
    "real_name",
    "phone_number",
    "real_audio",
    "real_conversation",
    "real_call_transcript",
    "real_session_log",
    "clinical_note",
    "diagnostic_label",
    "therapeutic_interpretation",
    "counseling_interpretation",
    "surveillance_flag",
    "relationship_verdict",
    "human_score",
    "human_rank",
    "sal_meter_raw_input",
    "cais_trace_data",
    "production_intervention_log"
  ],
  "prohibited_output_claims": [
    "validated_benchmark",
    "validated_mediation",
    "validated_recovery",
    "validated_termination_gate",
    "clinical_effectiveness",
    "diagnostic_accuracy",
    "therapeutic_effectiveness",
    "counseling_effectiveness",
    "real_human_state_measurement",
    "real_ai_impact_measurement",
    "relationship_verdict",
    "human_ranking",
    "sal_meter_validation",
    "cais_compliance",
    "certification",
    "device_readiness",
    "production_readiness",
    "production_closed_loop_authority"
  ],
  "terminal_summary": {
    "print_header": true,
    "print_boundary_flags": true,
    "print_condition_scores": true,
    "print_preferred_condition": true,
    "print_final_boundary": true
  },
  "final_boundary_statement": "This evaluator is synthetic-only and public-helper-only. It compares synthetic AI Output A/B consequence fields only. It is not validation, not clinical, not diagnostic, not therapeutic, not counseling, not surveillance, not mediation effectiveness validation, not benchmark validation, not scientific truth validation, not Sal-Meter, not CAIS compliance, not certification, not device readiness, not production readiness, and not production authority. A synthetic score must not be converted into a real human judgment."
}
